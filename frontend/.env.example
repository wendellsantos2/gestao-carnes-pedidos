# Em desenvolvimento, o Vite faz proxy de /api para http://localhost:5005 (veja vite.config.ts).
# Deixe comentado para usar o proxy local, ou defina a URL completa da API:
# VITE_API_URL=http://localhost:5005/api

# Cotações AwesomeAPI (proxy padrão: /cotacao/json/last/USD-BRL,EUR-BRL)
# VITE_COTACAO_API_URL=https://economia.awesomeapi.com.br/json/last/USD-BRL,EUR-BRL
